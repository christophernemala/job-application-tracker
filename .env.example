# ============================================================
# Job Application Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ---- Mode -------------------------------------------------------
# Set to false when you are ready to go live
MOCK_MODE=true

# ---- API Keys ---------------------------------------------------
APIFY_TOKEN=
OPENAI_API_KEY=
ZAPIER_WEBHOOK=            # optional — POST notification on each apply

# ---- Input Files (relative to inputs/) -------------------------
CV_FILE=cv_base.md
CV_TEMPLATE=cv_template.md

# ---- Search Parameters ------------------------------------------
SEARCH_KEYWORDS=accounts receivable,credit control,collections,billing,reconciliation,finance operations,AR analyst,finance officer
SALARY_MIN_AED=14000
SHORTLIST_THRESHOLD=60     # 0-100 score; jobs below this are skipped

# ---- Candidate Profile (used to pre-fill ATS forms) -------------
CANDIDATE_FIRST_NAME=
CANDIDATE_LAST_NAME=
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
CANDIDATE_LOCATION=Dubai, UAE
CANDIDATE_NATIONALITY=
CANDIDATE_VISA_STATUS=
CANDIDATE_NOTICE_PERIOD=1 month
CANDIDATE_CURRENT_SALARY=
CANDIDATE_YEARS_EXP=
CANDIDATE_LINKEDIN=

# ---- Apify Actor Overrides (optional) ---------------------------
ACTOR_LINKEDIN=apify/linkedin-jobs-scraper
ACTOR_INDEED=misceres/indeed-scraper
ACTOR_BAYT=apify/website-content-crawler
ACTOR_GULFTAIENT=apify/website-content-crawler

# ---- Scheduler --------------------------------------------------
SCHEDULE_HOUR=7            # UTC hour for daily run
SCHEDULE_MINUTE=0

# ---- Logging ----------------------------------------------------
LOG_LEVEL=INFO
