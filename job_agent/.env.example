# ─────────────────────────────────────────────────────────────────────────────
# Job Agent — Environment Variables Template
# Copy this file to job_agent/.env and fill in real values.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Naukri Gulf Credentials (REQUIRED for automation) ────────────────────────
NAUKRI_GULF_EMAIL=your-naukrigulf-email@example.com
NAUKRI_GULF_PASSWORD=your-naukrigulf-password

# ── User Profile (used in AI cover letter / resume generation) ───────────────
JOB_AGENT_NAME=Your Full Name
JOB_AGENT_EMAIL=your-email@example.com
JOB_AGENT_PHONE=+971-XXXXXXXXX
JOB_AGENT_LOCATION=Dubai, UAE
JOB_AGENT_CURRENT_ROLE=Your Current Job Title
JOB_AGENT_YEARS_EXPERIENCE=5+
JOB_AGENT_LINKEDIN=linkedin.com/in/your-profile

# ── Flask Dashboard Credentials ──────────────────────────────────────────────
# Change these before deploying — do not leave as defaults in production
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-before-deploy

# ── Flask Security ────────────────────────────────────────────────────────────
# Generate a random secret key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-random-secret-key

# ── OpenAI (OPTIONAL — enables AI cover letter & resume tailoring) ────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
