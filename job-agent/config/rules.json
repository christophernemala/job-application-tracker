{
  "include_keywords": [
    "accounts receivable",
    "AR",
    "order to cash",
    "O2C",
    "OTC",
    "credit control",
    "credit controller",
    "collections",
    "receivables",
    "credit risk",
    "dunning",
    "aging",
    "reconciliation",
    "dispute resolution",
    "cash application",
    "Oracle Fusion",
    "Oracle ERP",
    "SAP FICO",
    "ERP",
    "revenue recognition",
    "credit management",
    "debit note",
    "credit note",
    "DSO",
    "bad debt",
    "write-off",
    "payment allocation"
  ],
  "exclude_keywords": [
    "customer service only",
    "sales agent",
    "field collection",
    "door to door",
    "telemarketing",
    "internship",
    "fresh graduate",
    "fresher",
    "entry level",
    "junior accountant",
    "accounts payable only",
    "data entry",
    "receptionist",
    "warehouse",
    "driver"
  ],
  "title_include_patterns": [
    "(?i)\\b(senior|sr\\.?)\\s*(ar|accounts\\s*receivable)",
    "(?i)\\b(credit\\s*control|collections|receivable)",
    "(?i)\\b(o2c|order\\s*to\\s*cash|otc)",
    "(?i)\\b(credit\\s*risk|credit\\s*analyst)",
    "(?i)\\b(assistant\\s*manager|manager)\\s*(credit|collection|ar|receivable)",
    "(?i)\\bar\\s*(analyst|specialist|executive|lead)"
  ],
  "title_exclude_patterns": [
    "(?i)\\b(intern|trainee|fresher|junior)\\b",
    "(?i)\\b(customer\\s*service\\s*representative)\\b",
    "(?i)\\b(sales\\s*agent|field\\s*collector|tele.?caller)\\b",
    "(?i)\\b(accounts\\s*payable\\s*clerk|data\\s*entry)\\b"
  ],
  "min_score_for_auto_apply": 80,
  "min_score_for_semi_auto": 60,
  "min_score_for_manual_review": 40,
  "salary_floor": 14000,
  "salary_currency": "AED",
  "duplicate_window_days": 30,
  "max_applications_per_run": 10,
  "max_applications_per_day": 25,
  "seniority_levels_accepted": [
    "senior",
    "specialist",
    "executive",
    "lead",
    "assistant manager",
    "manager"
  ],
  "seniority_levels_rejected": [
    "intern",
    "trainee",
    "fresher",
    "junior",
    "entry level",
    "director",
    "vp",
    "chief"
  ],
  "scoring_weights": {
    "title_relevance": 30,
    "keyword_match": 20,
    "location_match": 15,
    "salary_fit": 10,
    "seniority_fit": 15,
    "erp_skill_match": 10
  }
}
